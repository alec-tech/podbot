# The Signal — Git Ignore
# ============================================================

# Environment & secrets — NEVER commit these
.env
.env.local
*.key
secrets.json

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
.venv/
venv/
env/

# Generated outputs — don't commit audio/scripts to git
outputs/
logs/

# Database
database/

# Injection data and archive (generated at runtime)
data/*/injected_stories.json
data/*/injection_archive/
data/admin/

# Legacy flat paths (pre-multi-show) — safe to delete after migration
data/injection_archive/
data/injected_stories.json
config/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Per-show website data IS committed (it's the website data source)
# website/the-signal/episodes.json  ← DO commit this
# website/the-signal/feed.xml       ← DO commit this
# website/the-rough/episodes.json   ← DO commit this
# website/the-rough/feed.xml        ← DO commit this
