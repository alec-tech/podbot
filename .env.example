# ============================================================
# THE SIGNAL — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git (it's in .gitignore).
# Add all of these as GitHub Secrets for the automated pipeline.
# ============================================================

# ── REQUIRED ── These must be set before anything will run ──────────────────

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ElevenLabs TTS — https://elevenlabs.io
ELEVENLABS_API_KEY=...
# Get these voice IDs from your ElevenLabs dashboard after selecting voices
ELEVENLABS_VOICE_ALEX=pNInz6obpgDQGcFmaJgB      # Default: Adam (authoritative)
ELEVENLABS_VOICE_MORGAN=21m00Tcm4TlvDq8ikWAM    # Default: Rachel (warm/enthusiastic)
ELEVENLABS_VOICE_DREW=AZnzlk1XvdvUeBnXmlld      # Default: Domi (analytical)

# Buzzsprout Podcast Hosting — https://buzzsprout.com
# Find your Podcast ID in the Buzzsprout URL: buzzsprout.com/YOUR_ID
BUZZSPROUT_API_KEY=...
BUZZSPROUT_PODCAST_ID=...

# ── RECOMMENDED ── The pipeline works without these but is better with them ─

# NewsAPI — https://newsapi.org (free tier: 100 req/day, plenty for daily show)
NEWS_API_KEY=...

# Slack Alerts — create an Incoming Webhook in your Slack workspace
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ── OPTIONAL: Social Media Auto-Posting ─────────────────────────────────────

# Twitter/X — https://developer.twitter.com
# Needs Elevated access for posting
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_TOKEN_SECRET=...

# LinkedIn — https://www.linkedin.com/developers
LINKEDIN_ACCESS_TOKEN=...
LINKEDIN_PERSON_ID=...        # Your LinkedIn member ID (not username)

# ── OPTIONAL: Cloud Storage for Audio Files ──────────────────────────────────
# Use Cloudflare R2 (cheaper) or AWS S3 for audio file hosting
# If not set, audio is uploaded directly via Buzzsprout

# AWS S3
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=the-signal-audio
AWS_REGION=us-east-1

# Cloudflare R2 (S3-compatible, cheaper egress)
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=the-signal-audio

# ── SHOW CONFIGURATION ───────────────────────────────────────────────────────

# Your podcast website URL (used in RSS feed and metadata)
PODCAST_WEBSITE_URL=https://yoursignalpodcast.com

# Email to receive Must-Include story tip notifications
PRODUCER_ALERT_EMAIL=you@yourdomain.com

# Tip form webhook (Formspree, Netlify Forms, or custom endpoint)
TIP_WEBHOOK_URL=https://formspree.io/f/YOUR_FORM_ID
