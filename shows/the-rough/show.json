{
  "show": {
    "name": "The Rough",
    "tagline": "Daily golf intelligence",
    "description": "Every weekday morning: one 10-15 minute episode covering PGA Tour action, equipment news, the business of golf, and course culture. AI-hosted, no fluff — just the stories that matter to serious golf fans.",
    "host_names": ["Jack Devlin", "Dana Park", "Ricky Santos", "Caroline Voss", "Theo Marsh"],
    "sponsor_slots": 3,
    "language": "en",
    "explicit": false,
    "category": "Sports",
