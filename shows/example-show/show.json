{
  "show": {
    "name": "Example Show",
    "tagline": "AI-powered news podcast — business, tech, and policy",
    "description": "A demonstration show with three daily editions. Business, tech, and policy news — curated, written, and hosted by AI.",
    "host_names": ["Chuck Leblanc", "Jessica Waverly", "Drew Vasquez", "Priya Nair", "Marcus Cole", "Sam Torres", "Jordan Blake"],
    "sponsor_slots": 3,
    "language": "en",
    "explicit": false,
    "category": "News",
    "subcategory": "Business News",
    "topic_domains": ["business", "tech", "policy"],
    "story_quotas": {
      "business_stories": 2,
      "overlap_stories": 1,
      "tech_stories": 2
    },
    "edition_order": ["morning", "midday", "evening"],
    "newsapi": {
      "mode": "categories",
      "categories": ["business", "technology"]
    },
    "source_tiers": {
      "tier1": ["Reuters", "Financial Times", "Wall Street Journal", "Bloomberg", "Economist", "MIT Technology Review", "IEEE Spectrum", "Politico"],
      "tier2": ["TechCrunch", "Wired", "Ars Technica", "CNBC", "Fortune", "VentureBeat", "The Verge", "Harvard Business Review", "The Hill"]
    },
    "editions": {
      "morning": {
        "publish_time_est": "07:00",
        "publish_time_utc": "12:00",
        "target_duration_minutes": 12,
        "min_duration_minutes": 10,
        "max_duration_minutes": 15,
        "title_format": "{date} Morning - {hook}",
        "news_window_hours": 14,
        "includes_recap": false
      },
      "midday": {
        "publish_time_est": "13:00",
        "publish_time_utc": "18:00",
        "target_duration_minutes": 12,
        "min_duration_minutes": 10,
        "max_duration_minutes": 15,
        "title_format": "{date} Midday - {hook}",
        "news_window_hours": 7,
        "includes_recap": false
      },
      "evening": {
        "publish_time_est": "17:30",
        "publish_time_utc": "22:30",
        "target_duration_minutes": 12,
        "min_duration_minutes": 10,
        "max_duration_minutes": 15,
        "title_format": "{date} Evening - {hook}",
        "news_window_hours": 5,
        "includes_recap": false
      }
    }
  },
