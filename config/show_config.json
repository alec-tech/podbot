{
  "show": {
    "name": "The Signal",
    "tagline": "Twice-daily business and tech intelligence",
    "description": "Every weekday: two episodes. The 4 AM edition recaps yesterday and covers overnight news. The 1 PM edition covers the morning. 43 minutes each. No filler.",
    "host_names": ["Alex Chen", "Morgan Lee", "Drew Vasquez"],
    "target_duration_minutes": 43,
    "sponsor_slots": 2,
    "language": "en",
    "explicit": false,
    "category": "News",
    "subcategory": "Business News",
    "editions": {
      "am": {
        "publish_time_est": "04:00",
        "publish_time_utc": "09:00",
        "sponsor_slot_1_time": "07:30",
        "sponsor_slot_2_time": "40:00",
        "title_format": "{date} AM - {hook}",
        "news_window_hours": 16,
        "includes_recap": true
      },
      "pm": {
        "publish_time_est": "13:00",
        "publish_time_utc": "18:00",
        "sponsor_slot_1_time": "15:00",
        "sponsor_slot_2_time": "40:00",
        "title_format": "{date} PM - {hook}",
        "news_window_hours": 10,
        "includes_recap": false
      }
    }
  },
  "voices": {
    "alex": {
      "description": "Business anchor — analytical, measured, authoritative",
      "elevenlabs_id_env": "ELEVENLABS_VOICE_ALEX",
      "stability": 0.55,
      "similarity_boost": 0.75,
      "style": 0.35
    },
    "morgan": {
      "description": "Tech correspondent — enthusiastic, substantive, fast-paced when excited",
      "elevenlabs_id_env": "ELEVENLABS_VOICE_MORGAN",
      "stability": 0.45,
      "similarity_boost": 0.75,
      "style": 0.50
    },
    "drew": {
      "description": "Strategy analyst — deliberate, contrarian, big-picture",
      "elevenlabs_id_env": "ELEVENLABS_VOICE_DREW",
      "stability": 0.60,
      "similarity_boost": 0.70,
      "style": 0.30
    }
  },
  "audio": {
    "output_format": "mp3",
    "bitrate": "192k",
    "sample_rate": 44100,
    "target_lufs": -16,
    "true_peak_dbtp": -1.5,
    "intro_music_duration_seconds": 8,
    "outro_music_duration_seconds": 10,
    "silence_between_lines_seconds": 0.35
  },
  "pipeline": {
    "min_duration_minutes": 40,
    "max_duration_minutes": 48,
    "retry_attempts": 3,
    "story_cooldown_days": 3,
    "fallback_to_previous_brief": true,
    "am_recap_stories": 3,
    "pm_excludes_am_stories": true
  }
}
